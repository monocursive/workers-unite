# Database
DATABASE_URL=ecto://postgres:postgres@localhost:5432/workers_unite_dev

# Phoenix secret (generate with: mix phx.gen.secret)
SECRET_KEY_BASE=

# Credential encryption key (generate with: mix phx.gen.secret 32)
CREDENTIAL_ENCRYPTION_KEY=

# AI provider API keys (at least one required for agent sessions)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MCP endpoint base URL (defaults to http://localhost:4000)
WORKERS_UNITE_MCP_BASE_URL=http://localhost:4000

# Server port (defaults to 4000)
PORT=4000
